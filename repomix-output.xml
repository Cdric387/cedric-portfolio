@import "tailwindcss";

/* ── Dark theme (default) ───────────────────────────── */
:root,
[data-theme="dark"] {
  --accent: #818cf8;
  --accent-glow: rgba(129, 140, 248, 0.2);
  --emerald: #34d399;
  --pink: #f472b6;
  --bg: #09090b;
  --bg-card: rgba(255, 255, 255, 0.025);
  --border: rgba(255, 255, 255, 0.07);
  --text: #fafafa;
  --muted: #71717a;
  --dot-color: rgba(255, 255, 255, 0.055);
  --font-display: var(--font-syne), sans-serif;
  --font-body: var(--font-dm-sans), sans-serif;
}

/* ── Light theme ────────────────────────────────────── */
[data-theme="light"] {
  --accent: #6366f1;
  --accent-glow: rgba(99, 102, 241, 0.15);
  --emerald: #10b981;
  --pink: #ec4899;
  --bg: #fafafa;
  --bg-card: rgba(0, 0, 0, 0.03);
  --border: rgba(0, 0, 0, 0.08);
  --text: #09090b;
  --muted: #71717a;
  --dot-color: rgba(0, 0, 0, 0.06);
  --font-display: var(--font-syne), sans-serif;
  --font-body: var(--font-dm-sans), sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background-color: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
  transition: background-color 0.3s ease, color 0.3s ease;
}

/* Dot grid */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: radial-gradient(var(--dot-color) 1px, transparent 1px);
  background-size: 30px 30px;
  pointer-events: none;
  z-index: 0;
}

/* Custom scrollbar */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: #27272a; border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: #3f3f46; }

/* Pulse animation for badge */
@keyframes pulse-dot {
  0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--emerald); }
  50%       { opacity: 0.5; box-shadow: 0 0 4px var(--emerald); }
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50%       { transform: translateY(-8px); }
}
